# ============================================================
# HƯỚNG DẪN: Copy file này thành .env rồi điền key thật vào
# ============================================================

# Key Gemini (Google AI Studio) - https://aistudio.google.com/app/apikey
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
# GEMINI_API_KEY_2=YOUR_SECOND_GEMINI_KEY  # Key dự phòng (tùy chọn)

# Key Groq (fallback miễn phí) - https://console.groq.com/keys
GROQ_API_KEY=YOUR_GROQ_API_KEY
